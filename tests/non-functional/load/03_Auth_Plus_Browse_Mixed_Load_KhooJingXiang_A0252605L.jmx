      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TG_Login_Session">
        <intProp name="ThreadGroup.num_threads">30</intProp>
        <intProp name="ThreadGroup.ramp_time">20</intProp>
